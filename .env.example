# Servidor
PORT=8080

# Base de datos local (ignorado si se define DB_URL)
DB_IP=127.0.0.1
DB_PORT=27017

# Base de datos MongoDB Atlas (reemplaza DB_IP y DB_PORT si se define)
DB_URL=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/SostekDB

# JWT — usar un string largo y aleatorio, nunca compartir
JWT_CODE=tu_secret_jwt_muy_largo_aqui

# Cloudinary — necesario solo para correr seed:presentations
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
