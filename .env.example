# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=8080

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Requerido. String largo y aleatorio — nunca compartir ni subir al repo.
JWT_CODE=

# ─── Base de datos ────────────────────────────────────────────────────────────
# Opción A — MongoDB Atlas (recomendado). Si se define DB_URL, se ignoran DB_IP y DB_PORT.
DB_URL=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/SostekDB

# Opción B — MongoDB local (desarrollo sin Atlas).
DB_IP=127.0.0.1
DB_PORT=27017

# ─── Email (Nodemailer + Gmail) ───────────────────────────────────────────────
# Requerido para enviar emails de recuperación de contraseña.
# EMAIL_PASS debe ser una "Contraseña de aplicación" de Google (no la contraseña normal).
# Cómo obtenerla: Cuenta Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
EMAIL_USER=tu-cuenta@gmail.com
EMAIL_PASS=

# URL base del frontend — se usa para armar el link de reset en el email.
FRONTEND_URL=http://localhost:3000

# Origen CORS extra — agregar la URL del frontend en producción (ej: https://sostek.pages.dev)
# En desarrollo no hace falta definirla.
CORS_ORIGIN=

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Requerido solo para correr seed/seedPresentations.js.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
